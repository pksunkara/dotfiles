[
  // Redo
  {
    "key": "cmd+y",
    "command": "redo",
    "when": "isMac"
  },
  {
    "key": "shift+cmd+z",
    "command": "-redo",
    "when": "isMac"
  },
  {
    "key": "shift+ctrl+z",
    "command": "-redo",
    "when": "!isMac"
  },
  // Explorer
  {
    "key": "cmd+a",
    "command": "explorer.newFile",
    "when": "isMac && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "ctrl+a",
    "command": "explorer.newFolder",
    "when": "isMac && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "ctrl+a",
    "command": "explorer.newFile",
    "when": "!isMac && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "cmd+a",
    "command": "explorer.newFolder",
    "when": "!isMac && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "alt+a",
    "command": "extension.newModuleFromTemplate",
    "when": "!explorerResourceReadonly && !inputFocus"
  },
  // Projects
  {
    "key": "ctrl+cmd+p",
    "command": "projects.open"
  },
  {
    "key": "alt+cmd+p",
    "command": "-projects.open"
  },
  {
    "key": "ctrl+cmd+g",
    "command": "projects.openGroup"
  },
  {
    "key": "shift+alt+cmd+x",
    "command": "-projects.openGroup"
  },
  {
    "key": "ctrl+cmd+x",
    "command": "projects.switchGroup"
  },
  {
    "key": "alt+cmd+x",
    "command": "-projects.switchGroup"
  },
  //
  {
    "key": "cmd+r",
    "command": "workbench.action.gotoSymbol"
  },
  {
    "key": "shift+cmd+o",
    "command": "-workbench.action.gotoSymbol"
  },
  {
    "key": "cmd+m",
    "command": "editor.action.toggleMinimap"
  },
  {
    "key": "shift+cmd+f",
    "command": "-workbench.view.search"
  },
  {
    "key": "alt+f",
    "command": "workbench.view.search"
  }
]
